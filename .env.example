# =============================================================================
# Catalog Monitor — пример конфигурации
# =============================================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# Файл .env НЕ должен попадать в систему контроля версий.
# =============================================================================

# --- Telegram Bot ---
# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram ID администратора (числовой)
ADMIN_ID=123456789

# --- XML-фиды ---
STORE_FEED_URL=https://st.sunlight.net/media/feed/outlets/yandex_outlets_mcz.xml
PRODUCT_FEED_URL=https://st.sunlight.net/media/feed/anyquery_mcz.xml

# --- База данных ---
# SQLite (по умолчанию). Путь разрешается относительно каталога data/
DATABASE_URL=sqlite+aiosqlite:///./data/catalog_monitor.db

# --- Непрерывный фоновый мониторинг ---
# Интервал скачивания фидов (секунды). 10800 = 3 часа
FEED_DOWNLOAD_INTERVAL=10800

# Максимальная длительность одной проверки (секунды). 10740 = 2 ч 59 мин
MAX_CHECK_DURATION_SECONDS=10740

# Резерв времени на локальные проверки (парсинг XML, структура, поля), секунды.
# Оставшееся время (MAX_CHECK − LOCAL_CHECK) распределяется на HTTP-проверки URL.
LOCAL_CHECK_RESERVE_SECONDS=600

# --- HTTP-запросы ---
# Таймаут одного запроса в секундах
REQUEST_TIMEOUT=30

# --- Логирование ---
# Уровни: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Режим проверки ---
# FAST — доступность, структура, обязательные поля, страницы товаров
# FULL — дополнительно: все изображения, Content-Type, размеры, дубли
CHECK_MODE=FAST

# --- Флаги проверок ---
CHECK_PRODUCT_IMAGES=true
CHECK_STORE_IMAGES=true
CHECK_SOCIAL_LINKS=false

# --- Пороги и лимиты ---
# Максимальный возраст фида товаров (минуты)
MAX_PRODUCT_FEED_AGE_MINUTES=180

# Максимальный возраст фида магазинов (минуты)
MAX_STORE_FEED_AGE_MINUTES=180

# Порог резкого изменения количества товаров (%)
MAX_PRODUCT_COUNT_CHANGE_PERCENT=20

# Порог резкого изменения количества магазинов (%)
MAX_STORE_COUNT_CHANGE_PERCENT=20

# Максимальный возраст actualization-date магазина (дни)
MAX_OUTLET_AGE_DAYS=3

# Порог подозрительно низкой цены товара (руб.)
MIN_PRODUCT_PRICE_WARNING=100

# Порог резкого изменения цены товара между проверками (%)
MAX_PRICE_CHANGE_PERCENT=50

# Порог резкого изменения размера XML-фида между проверками (%)
MAX_FEED_SIZE_CHANGE_PERCENT=15

# --- Хранение данных и контроль размера БД ---
# Срок хранения записей в БД: журнал авторизации, история проверок, история ошибок
DATA_RETENTION_DAYS=3

# Срок хранения файлов логов (дни)
LOG_RETENTION_DAYS=3

# Интервал автоматической очистки (секунды, по умолчанию раз в сутки)
DB_CLEANUP_INTERVAL=86400
